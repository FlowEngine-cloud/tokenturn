[
  {
    "request": {
      "method": "POST",
      "url": "https://api.linear.app/graphql",
      "body": {
        "query": "query Issues($from: DateTimeOrDuration!, $to: DateTimeOrDuration!, $after: String) { issues(first: 50, after: $after, filter: { updatedAt: { gte: $from, lt: $to } }) { nodes { identifier title url createdAt team { key } state { name type } creator { id displayName email app } assignee { id displayName email app } delegate { id displayName email app } history(first: 50) { nodes { createdAt fromState { name type } toState { name type } } } } pageInfo { hasNextPage endCursor } } }",
        "variables": {
          "from": "2025-06-11T00:00:00.000Z",
          "to": "2026-06-12T00:00:00.000Z",
          "after": null
